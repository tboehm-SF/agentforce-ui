# Copy this to .env.local and fill in your values

# ── Frontend (Vite) ──────────────────────────────────────────────────────────

# Your Salesforce org URL (no trailing slash)
VITE_SF_INSTANCE_URL=https://hls-ch.my.salesforce.com

# Connected App Consumer Key (for OAuth flow — used when VITE_SHOWCASE_MODE=false)
# Setup → App Manager → Your Connected App → Consumer Key
VITE_SF_CLIENT_ID=

# Org ID (optional, found in Setup → Company Information)
VITE_SF_ORG_ID=

# Set to "true" on Heroku to skip the login screen.
# The Express server will use SF_CLIENT_ID / SF_CLIENT_SECRET instead.
VITE_SHOWCASE_MODE=false

# ── Server (Express / Heroku config vars) ────────────────────────────────────

# Salesforce Connected App — Client Credentials OAuth
# Requires: "Client Credentials" flow enabled on the Connected App
SF_BASE_URL=https://hls-ch.my.salesforce.com
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_API_VERSION=v62.0

# Set automatically by Heroku — don't add these manually:
# PORT=...
# NODE_ENV=production
